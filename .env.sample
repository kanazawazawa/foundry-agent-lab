# Microsoft Foundry プロジェクトのエンドポイント
# 例: https://<account_name>.services.ai.azure.com/api/projects/<project_name>
PROJECT_ENDPOINT=

# モデルデプロイ名
MODEL_DEPLOYMENT_NAME=gpt-5.4

# エージェント名
AGENT_NAME=travel-expense-helpdesk

# 発行済み Agent Application のベース URL（published-agent/ の検証スクリプトで使用）
# 例: https://<account_name>.services.ai.azure.com/api/projects/<project_name>/applications/<agent_name>/protocols/openai
AGENT_APP_BASE_URL=
